{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/*.{css,js,mjs,json,map,txt,xml,ico,png,jpg,jpeg,gif,svg,webp,avif,woff,woff2,ttf,eot}"
    ]
  },
  "globalHeaders": {
    "cache-control": "no-cache",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
